{
  "name": "Pocket Dragon Creator Lab",
  "sourceSaveFile": "~/Library/Application Support/Pocket Dragon/creature.json",
  "description": "Creator schema for live-testing every creature save attribute from the menu and burrow interface. Read-only fields are included so the creator surface tracks the full save contract.",
  "attributes": [
    {
      "key": "schema",
      "type": "integer",
      "editable": false,
      "notes": "Save-file schema version."
    },
    {
      "key": "species",
      "type": "string",
      "editable": false,
      "values": ["dragon"],
      "notes": "Future creature types will plug in here."
    },
    {
      "key": "name",
      "type": "string",
      "editable": true,
      "control": "Rename..."
    },
    {
      "key": "birthTime",
      "type": "timestamp",
      "editable": true,
      "control": "Age / Stage",
      "presets": [
        { "label": "Hatchling, day 0", "ageDays": 0 },
        { "label": "Juvenile, day 7", "ageDays": 7 },
        { "label": "Adolescent, day 21", "ageDays": 21 },
        { "label": "Adult, day 45", "ageDays": 45 },
        { "label": "Elder, day 90", "ageDays": 90 }
      ]
    },
    {
      "key": "lifeStage",
      "type": "string",
      "editable": false,
      "derivedFrom": "birthTime",
      "values": ["Hatchling", "Juvenile", "Adolescent", "Adult", "Elder"]
    },
    {
      "key": "favoriteFood",
      "type": "string",
      "editable": true,
      "control": "Favorite Food",
      "values": ["meteor berries", "smoked sun-meat", "crunchy fern sprouts", "moon sugar", "starfruit cubes"]
    },
    {
      "key": "favoriteColor",
      "type": "string",
      "editable": true,
      "control": "Favorite Color / Palette",
      "values": ["sky blue", "ember coral", "moss green", "moonlit violet", "carnival bright"]
    },
    {
      "key": "lastAppName",
      "type": "string",
      "editable": true,
      "control": "Last App",
      "values": ["Cursor", "Figma", "Terminal", "Safari", "BambuStudio", "Notes"]
    },
    {
      "key": "hunger",
      "type": "number",
      "editable": true,
      "control": "Stats > hunger",
      "range": [0, 100],
      "presets": [0, 25, 50, 75, 100]
    },
    {
      "key": "affection",
      "type": "number",
      "editable": true,
